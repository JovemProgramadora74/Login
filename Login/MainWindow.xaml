<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#264ECA">
        <StackPanel Margin="20">
            <TextBlock FontFamily="Consolas" Width="300" Foreground="White" Text="Nome de Usuário" />
            <TextBox Width="300" Height="45" FontSize="16" x:Name="tbUsuario" />

            <TextBlock Width="300" Foreground="White" Text="Senha" />
            <TextBox Margin="0 0 0 40" Width="300" Height="45" FontSize="16" x:Name="tbSenha" />

            <Button Background="White" Foreground="#2148C0" Width="300" Height="45" Content="Fazer login" Click="BotaoLogin" />
            <Button Background="White" Foreground="#2148C0" Width="300" Height="45" Content="Cadastre-se" Click="BotaoCadastro" />
        </StackPanel>
    </Grid>
</Window>